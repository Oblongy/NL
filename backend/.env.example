HOST=127.0.0.1
PORT=8082
# TCP_PORT=3724 is the default port for Nitto Legends TCP features
# Note: Port 3724 may conflict with Blizzard services (WoW, Battle.net)
# If you need to run both, either:
#   1. Stop the IP Helper service (iphlpsvc) temporarily
#   2. Use a different port and configure port forwarding
TCP_PORT=3724
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
